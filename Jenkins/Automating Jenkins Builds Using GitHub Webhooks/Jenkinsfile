pipeline {
    agent any

    stages {
        stage('Run Script') {
            steps {
                sh 'chmod +x Jenkins/Automating Jenkins Builds Using GitHub Webhooks/script.sh'
                sh 'sh Jenkins/Automating Jenkins Builds Using GitHub Webhooks/script.sh'
            }
        }
    }

    post {
        success {
            emailext(
                subject: "SUCCESS: JENKINS BUILD",
                body: "Build completed successfully.",
                to: "ragu.cloudjourney@gmail.com"
            )
        }

        failure {
            emailext(
                subject: "FAILED: !!!Jenkins Build!!!",
                body: "Build failed.",
                to: "ragu.cloudjourney@gmail.com"
            )
        }
    }
}
